// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserType {
  ev_sahibi
  ev_arayan
}

enum Occupation {
  ogrenci
  calisan
  emekli
  issiz
  diger
}

enum MaritalStatus {
  bekar
  evli
}

enum Gender {
  erkek
  kadin
}

enum SearchType {
  evime_arkadas
  kalacak_ev
  beraber_ev
}

// ==================== MODELS ====================

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  password        String
  fullName        String
  phone           String
  age             Int
  occupation      Occupation
  occupationOther String?
  maritalStatus   MaritalStatus
  gender          Gender
  userType        UserType      @default(ev_arayan)
  profileImage    String?
  bio             String?
  isVerified      Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  traits            UserTraits?
  properties        Property[]
  listings          Listing[]
  sentMessages      Message[]      @relation("SentMessages")
  receivedMessages  Message[]      @relation("ReceivedMessages")
  favorites         Favorite[]
  conversations1    Conversation[] @relation("Participant1")
  conversations2    Conversation[] @relation("Participant2")
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([userType])
  @@index([gender])
}

model UserTraits {
  id          String  @id @default(cuid())
  userId      String  @unique
  cleanliness Int     @default(3) // 1-5
  tidiness    Int     @default(3) // 1-5
  cooking     Int     @default(3) // 1-5
  smoking     Boolean @default(false)
  alcohol     Boolean @default(false)
  pets        Boolean @default(false)
  guests      Boolean @default(true)
  nightOwl    Boolean @default(false)
  earlyBird   Boolean @default(false)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id               String   @id @default(cuid())
  ownerId          String
  title            String
  description      String
  city             String
  district         String
  neighborhood     String?
  address          String?
  roomCount        Int
  bathroomCount    Int      @default(1)
  squareMeters     Int
  floor            Int      @default(0)
  totalFloors      Int      @default(1)
  buildingAge      Int      @default(0)
  furnished        Boolean  @default(false)
  rentPrice        Int
  deposit          Int?
  bills            Int?
  availableRooms   Int      @default(1)
  currentOccupants Int      @default(0)
  maxOccupants     Int      @default(1)
  preferredGender  Gender?
  images           String[] @default([])
  amenities        String[] @default([])
  rules            String[] @default([])
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([ownerId])
  @@index([city])
  @@index([district])
  @@index([rentPrice])
  @@index([isActive])
}

model Listing {
  id               String     @id @default(cuid())
  userId           String
  searchType       SearchType
  title            String
  description      String
  
  // Location
  city             String
  district         String?
  neighborhood     String?
  
  // Price - evime_arkadas uses rentPrice, others use minBudget/maxBudget
  rentPrice        Int?       // For evime_arkadas (single price)
  minBudget        Int?       // For kalacak_ev, beraber_ev (min budget)
  maxBudget        Int?       // For kalacak_ev, beraber_ev (max budget)
  
  // Room details
  roomCount        Int?       // Number of rooms in the house
  squareMeters     Int?       // Room/house square meters
  furnished        Boolean?   // Is room/house furnished
  
  // For beraber_ev
  peopleCount      Int?       // How many people looking together
  
  desiredRoomCount Int?       // Desired room count preference
  moveInDate       DateTime?
  duration         Int?       // Months
  preferredGender  Gender?
  
  // Images
  images           String[]   @default([])
  
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([userId])
  @@index([searchType])
  @@index([city])
  @@index([isActive])
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  listingId  String?
  createdAt  DateTime @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@unique([userId, listingId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
